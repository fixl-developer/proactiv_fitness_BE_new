{
    "name": "proactiv-fitness-backend",
    "version": "1.0.0",
    "description": "Enterprise-level youth fitness platform backend",
    "main": "dist/server.js",
    "scripts": {
        "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
        "build": "node build.js",
        "start": "node dist/server.js",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "migrate": "ts-node -r tsconfig-paths/register src/database/migrations/runner.ts",
        "seed": "ts-node -r tsconfig-paths/register src/database/seeds/runner.ts",
        "seed:support": "ts-node -r tsconfig-paths/register src/scripts/seed-support-data.ts",
        "seed:support:clear": "ts-node -r tsconfig-paths/register src/scripts/seed-support-data.ts --clear"
    },
    "keywords": [
        "fitness",
        "youth",
        "enterprise",
        "scheduling",
        "booking"
    ],
    "author": "Proactiv Fitness",
    "license": "PROPRIETARY",
    "dependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/lodash": "^4.14.202",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.6",
        "@types/nodemailer": "^6.4.14",
        "@types/pdfkit": "^0.17.6",
        "@types/uuid": "^9.0.7",
        "agenda": "^5.0.0",
        "bcryptjs": "^2.4.3",
        "cloudinary": "^2.9.0",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "date-fns": "^3.0.6",
        "dotenv": "^16.3.1",
        "exceljs": "^4.4.0",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "ioredis": "^5.3.2",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "lodash": "^4.17.21",
        "mongoose": "^7.8.9",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^8.0.1",
        "openai": "^4.73.0",
        "pdfkit": "^0.18.0",
        "redis": "^4.6.12",
        "socket.io": "^4.8.3",
        "stripe": "^14.9.0",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0",
        "twilio": "^4.19.3",
        "typescript": "^5.3.3",
        "uuid": "^9.0.1",
        "winston": "^3.11.0",
        "winston-daily-rotate-file": "^4.7.1"
    },
    "devDependencies": {
        "@types/jest": "^29.5.11",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.2",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.1",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}
