# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_NAME=Proactiv Fitness Platform

# Database
MONGODB_URI=mongodb://localhost:27017/proactiv_fitness
MONGODB_TEST_URI=mongodb://localhost:27017/proactiv_fitness_test

# Redis (Optional - for caching and queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@proactivfitness.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payment Gateways
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAY_API_KEY=
PAYPAY_SECRET_KEY=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret

# Feature Flags
ENABLE_REDIS=false
ENABLE_EMAIL=true
ENABLE_SMS=false
ENABLE_PAYMENTS=true

# Multi-tenancy
DEFAULT_TENANT=proactiv-hq

# AI / OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048
OPENAI_RATE_LIMIT_PER_MINUTE=60
ENABLE_AI=true
AI_CACHE_TTL=300
